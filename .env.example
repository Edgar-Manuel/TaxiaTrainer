# ─── Supabase (obligatorias para modo producción) ───────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── IA (cualquier API compatible con OpenAI) ───────────────────────────
AI_API_KEY=sk-or-...
AI_MODEL=google/gemini-2.5-flash
AI_BASE_URL=https://openrouter.ai/api/v1
# Alternativas:
# AI_BASE_URL=https://api.openai.com/v1          # OpenAI directo
# AI_BASE_URL=https://api.deepseek.com/v1         # DeepSeek
# AI_BASE_URL=http://localhost:11434/v1            # Ollama local

# ─── Mapas (opcional — sin ella se usan teselas gratuitas) ──────────────
NEXT_PUBLIC_MAPTILER_KEY=
